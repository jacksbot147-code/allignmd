# AlignMD — environment
# Copy to .env.local and fill from your Supabase project (Settings -> API).
# .env.local is gitignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for the daily job-feed cron (Vercel cron -> /api/jobs/refresh).
# Set this in production so the scheduled refresh can authenticate; if left
# unset the cron cannot run and only interactive staff refreshes work.
CRON_SECRET=
